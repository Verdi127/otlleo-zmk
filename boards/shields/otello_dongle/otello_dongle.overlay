// Documentation: https://zmk.dev/docs/development/hardware-integration/dongle
#include <dt-bindings/zmk/matrix_transform.h>
#include "../../config/otello-layouts.dtsi"

&otello_physical_layout {
    transform = <&default_transform>;
};

/ {
    chosen {
        zmk,kscan           = &kscan0;
        zmk,physical-layout = &otello_physical_layout;
        zmk,input-device    = &trackball_split;
        zephyr,display      = &oled;
    };

    kscan0: kscan_1 {
        compatible = "zmk,kscan-mock";
        columns    = <0>;
        rows       = <0>;
        events     = <0>;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <10>;
        rows = <4>;

        map = <
	RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)  RC(0,10) RC(0,9) RC(0,8) RC(0,7) RC(0,6)
	RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)  RC(1,10) RC(1,9) RC(1,8) RC(1,7) RC(1,6)
	RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)  RC(2,10) RC(2,9) RC(2,8) RC(2,7) RC(2,6)
					RC(3,3) RC(3,4) RC(3,1)  RC(3,6)  RC(3,8)
        >;
    };

    central: bt_central {
        compatible = "zmk,ble-central";
        peripherals = <&left_peripheral &right_peripheral>;
    };

    left_peripheral: bt_left {
        compatible = "zmk,ble-peripheral";
        local-name = "otello_left";
    };

    right_peripheral: bt_right {
        compatible = "zmk,ble-peripheral";
        local-name = "otello_right";
    };

    /* The dongle is the central - it receives trackball data over BLE from the
       right peripheral via zmk,input-split. No SPI or PMW3610 hardware here. */
    split_inputs {
        #address-cells = <1>;
        #size-cells = <0>;

        trackball_split: trackball_split@0 {
            compatible = "zmk,input-split";
            reg = <0>;
        };
    };

    trackball_listener: trackball_listener {
        compatible = "zmk,input-listener";
        status = "disabled";
        device = <&trackball_split>;
    };
};

/* Ambient light sensor not installed on dongle - disable I2C1 to prevent
   nRF52840 TWIM from hanging on probe (no ACK -> WDT reset loop) */
&i2c1 { status = "disabled"; };

&pro_micro_i2c {
    status = "okay";

    oled: sh1106@3c {
        compatible = "sinowealth,sh1106";
        reg = <0x3c>;
        width = <128>;
        height = <64>;
        segment-offset = <2>;
        page-offset = <0>;
        display-offset = <0>;
        multiplex-ratio = <63>;
        segment-remap;
        com-invdir;
        inversion-on;
        prechargep = <0x22>;
    };
};

/* otello_pointer.dtsi references &trackball_listener - must come after node definition */
#include "../../config/trackball/otello_pointer.dtsi"

&trackball_split {
    status = "okay";
};

&trackball_listener {
    status = "okay";
};
